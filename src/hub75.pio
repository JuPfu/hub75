.pio_version 0 // only requires PIO version 0

.program hub75_row

; side-set pin 0 is LATCH
; side-set pin 1 is OEn
;
; OUT pins are row select A-E
;
; Each TX FIFO record consists of three 32-bit words consumed in order:
;   Word 0 [bits 4:0]  — 5-bit row select (A–E address lines)
;          [bits 31:5] — unused (discarded by out null, 27)
;   Word 1 [31:0]      — lit_cycles:  OEn asserted duration (panel ON),
;                        BCM weighted, scaled by brightness_fp
;   Word 2 [31:0]      — dark_cycles: OEn deasserted duration (panel OFF),
;                        = (basis_factor << bit_plane) - lit_cycles
;
; Invariant: lit_cycles + dark_cycles = basis_factor << bit_plane (constant),
; guaranteeing a brightness-independent frame rate.
;
; Two RX FIFO pushes are produced per record (consumed by ping-pong DMA):
;   Push 1 (in y, 32): after LATCH — signals oen_lit_chan to start pixel_chan[N+1]
;   Push 2 (in x, 32): after dark_loop — signals oen_finished_chan to restart oen_chan
;
; Repeatedly select a row, pulse LATCH, and generate a pulse of a certain width on OEn (Binary Coded Modulation - BCM).

.side_set 2

.wrap_target
    in x, 32           side 0b10  ; Push random data to RX FIFO → triggers row_start_chan -> row_start_handler ->
                                  ; start pixel_chan[N+1] -chained-> dummy_pixel_chan -chained-> oen_chan
    out x, 32          side 0b10  ; Load lit_cycles (word 1) into X
dark_loop:
    jmp x-- dark_loop   side 0b10 ; Assert OEn for x+1 cycles (panel ON)
    out x, 32          side 0b10  ; Deassert OEn, load dark_cycles (word 2) into X
lit_loop:
    jmp x-- lit_loop  side 0b00   ; Deassert OEn for dark_cycles+1 cycles (panel OFF)
    in x, 32          side 0b00   ; oen_finished
    mov x, y           side 0b10  ; Copy wait cycles from Y register into X register
wait_loop:
    jmp x-- wait_loop  side 0b10  ; Wait for row to latch
    out pins, 5  [7]   side 0b11  ; Deassert OEn, output 5-bit row select (bits [4:0] of word 0)
    out null, 27       side 0b10  ; Discard bits [31:5] of word 0 (row_address in [4:0] only)
.wrap

% c-sdk {
static inline void hub75_row_program_init(PIO pio, uint sm, uint offset, uint row_base_pin, uint n_row_pins, uint latch_base_pin, uint wait_cycles) {
    pio_sm_set_consecutive_pindirs(pio, sm, row_base_pin, n_row_pins, true);
    pio_sm_set_consecutive_pindirs(pio, sm, latch_base_pin, 2, true);
    for (uint i = row_base_pin; i < row_base_pin + n_row_pins; ++i)
        pio_gpio_init(pio, i);
    pio_gpio_init(pio, latch_base_pin); // aka STROBE pin
    pio_gpio_init(pio, latch_base_pin + 1); // OEn pin

    pio_sm_config c = hub75_row_program_get_default_config(offset);
    sm_config_set_out_pins(&c, row_base_pin, n_row_pins);
    sm_config_set_sideset_pins(&c, latch_base_pin); // STROBE pin and OEn pin
    sm_config_set_in_shift(&c, true, true, 32);
    sm_config_set_out_shift(&c, true, true, 32);
    pio_sm_init(pio, sm, offset, &c);

    // Part of Pimoronis anti ghosting solution https://github.com/pimoroni/pimoroni-pico/commit/9e7c2640d426f7b97ca2d5e9161d3f0a00f21abf
    // Load wait_cycles into Y-register
    pio_sm_exec(pio, sm, pio_encode_out(pio_y, 32));
    pio_sm_put(pio, sm, wait_cycles);

    pio_sm_set_enabled(pio, sm, true);
}
%}

.program hub75_row_inverted

; side-set pin 0 is LATCH
; side-set pin 1 is OEn
; OUT pins are row select A-E
;
; Each FIFO record consists of three 32-bit words consumed in order:
;   Word 0 [bits 4:0]  — 5-bit row select (A–E address lines)
;          [bits 31:5] — unused (discarded by out null, 27)
;   Word 1 [31:0]      — lit_cycles:  OEn asserted duration (panel ON),
;                        BCM weighted, scaled by brightness_fp
;   Word 2 [31:0]      — dark_cycles: OEn deasserted duration (panel OFF),
;                        = (basis_factor << bit_plane) - lit_cycles
;
; Invariant: lit_cycles + dark_cycles = basis_factor << bit_plane (constant),
; guaranteeing a brightness-independent frame rate.
;
; The in x, 32 at the end pushes 0xFFFFFFFF to the RX FIFO, which triggers
; oen_finished_chan DMA and ultimately fires the oen_finished_handler() ISR.
;
; Repeatedly select a row, pulse LATCH, and generate a pulse of a certain
; width on OEn (Binary Coded Modulation - BCM).

.side_set 2

.wrap_target
    out pins, 5  [7]   side 0b11 ; Deassert OEn, output 5-bit row select (bits [4:0] of word 0)
    out null, 27       side 0b11 ; Discard bits [31:5] of word 0 (row_address in [4:0] only)
    mov x, y           side 0b11 ; Copy wait cycles from Y register into X register
wait_loop:
    jmp x-- wait_loop  side 0b10 ; Wait for row to latch
    in x, 32           side 0b11 ; Push random data to RX FIFO → triggers row_start_chan -> row_start_handler ->
                                 ; start pixel_chan[N+1] -chained-> dummy_pixel_chan -chained-> oen_chan
    out x, 32          side 0b11 ; Load lit_cycles (word 1) into X
lit_loop:
    jmp x-- lit_loop   side 0b01 ; Assert OEn for x+1 cycles (panel ON)
    out x, 32          side 0b11 ; Deassert OEn, load dark_cycles (word 2) into X
dark_loop:
    jmp x-- dark_loop  side 0b11 ; Deassert OEn for dark_cycles+1 cycles (panel OFF)
.wrap

% c-sdk {
static inline void hub75_row_inverted_program_init(PIO pio, uint sm, uint offset, uint row_base_pin, uint n_row_pins, uint latch_base_pin, uint wait_cycles) {
    pio_sm_set_consecutive_pindirs(pio, sm, row_base_pin, n_row_pins, true);
    pio_sm_set_consecutive_pindirs(pio, sm, latch_base_pin, 2, true);
    for (uint i = row_base_pin; i < row_base_pin + n_row_pins; ++i)
        pio_gpio_init(pio, i);
    pio_gpio_init(pio, latch_base_pin); // aka STROBE pin
    pio_gpio_init(pio, latch_base_pin + 1); // OEn pin

    pio_sm_config c = hub75_row_inverted_program_get_default_config(offset);
    sm_config_set_out_pins(&c, row_base_pin, n_row_pins);
    sm_config_set_sideset_pins(&c, latch_base_pin); // STROBE pin and OEn pin
    sm_config_set_in_shift(&c, true, true, 32);
    sm_config_set_out_shift(&c, true, true, 32);
    pio_sm_init(pio, sm, offset, &c);

    // Part of Pimoronis anti ghosting solution https://github.com/pimoroni/pimoroni-pico/commit/9e7c2640d426f7b97ca2d5e9161d3f0a00f21abf
    // Load wait_cycles into Y-register
    pio_sm_exec(pio, sm, pio_encode_out(pio_y, 32));
    pio_sm_put(pio, sm, wait_cycles);

    pio_sm_set_enabled(pio, sm, true);
}
%}

.program hub75_data_rgb
.define BIT_DEPTH 10               ; Placeholder - will be overwritten in hub75_data_rgb_program_init
.side_set 1

; Each FIFO record consists of a RGB101010 pixel. (This is ok for e.g. an RGB888
; source which has been gamma-corrected)
;
; Even pixels are sent on R0, G0, B0 and odd pixels on R1, G1, B1 (typically
; these are for different parts of the screen, NOT for adjacent pixels, so the
; frame buffer must be interleaved before passing to PIO.)
;
; Each pass through, we take bit n, n + 10 and n + 20 from each pixel, for n in
; {0...9}. Therefore the pixels need to be transmitted 10 times (ouch) to build
; up the full 10 bit value for each channel, and perform bit-planed PWM by
; varying pulse widths on the other state machine, in ascending powers of 2.
; This avoids a lot of bit shuffling on the processors, at the cost of DMA
; bandwidth (which we have loads of).

; Might want to close your eyes before you read this
public entry_point:
.wrap_target

public shift0:                     ; R0 G0 B0 (Top half of 64x64 displays)
    pull                    side 0 ; gets patched to `out null, n` if n nonzero (otherwise the PULL is required for fencing)
    in osr, 1               side 0 ; Red0 N
public out_red0:
    out null, BIT_DEPTH     side 0 ; Red0 discard

    in osr, 1               side 0 ; Green0 N
public out_green0:
    out null, BIT_DEPTH     side 0 ; Green0 discard

    in osr, 1               side 0 ; Blue0 N
    out null, 32            side 0 ; Remainder discard

public shift1:                     ; R1 G1 B1 (Bottom half of 64x64 displays)
    pull                    side 0 ; gets patched to `out null, n` if n nonzero (otherwise the PULL is required for fencing)
    in osr, 1               side 1 ; Red1 N
public out_red1:
    out null, BIT_DEPTH     side 1 ; Red1 discard

    in osr, 1               side 1 ; Green1 N
public out_green1:
    out null, BIT_DEPTH     side 1 ; Green1 discard

    in osr, 1               side 1 ; Blue1 N
    out null, 32            side 1 ; Remainder discard

    in null, 26             side 1 ; Note we are just doing this little manoeuvre here to get GPIOs in the order
    mov pins, ::isr         side 1 ; R0, G0, B0, R1, G1, B1. Can go 1 cycle faster if reversed

.wrap
; Note that because the clock edge for pixel n is in the middle of pixel n +
; 1, a dummy pixel at the end is required to clock the last piece of genuine
; data. (Also 1 pixel of garbage is clocked out at the start, but this is
; harmless)

% c-sdk {
#include "hub75.hpp"

static inline void hub75_data_rgb_program_init(PIO pio, uint sm, uint offset, uint rgb_base_pin, uint clock_pin) {
    pio_sm_set_consecutive_pindirs(pio, sm, rgb_base_pin, 6, true);
    pio_sm_set_consecutive_pindirs(pio, sm, clock_pin, 1, true);
    for (uint i = rgb_base_pin; i < rgb_base_pin + 6; ++i)
        pio_gpio_init(pio, i);
    pio_gpio_init(pio, clock_pin);

    pio_sm_config c = hub75_data_rgb_program_get_default_config(offset);
    sm_config_set_out_pins(&c, rgb_base_pin, 6);
    sm_config_set_sideset_pins(&c, clock_pin);
    sm_config_set_out_shift(&c, true, true, 32);
    // ISR shift to left. R0 ends up at bit 5. We push it up to MSB and then flip the register.
    sm_config_set_in_shift(&c, false, false, 32);
    sm_config_set_fifo_join(&c, PIO_FIFO_JOIN_TX);
    pio_sm_init(pio, sm, offset, &c);

    // set BIT_DEPTH
    uint instr = pio_encode_out(pio_null, BIT_DEPTH); 
    uint side_0 = pio_encode_sideset (1, 0);
    uint side_1 = pio_encode_sideset (1, 1);
    pio->instr_mem[offset + hub75_data_rgb_offset_out_red0] = instr | side_0;
    pio->instr_mem[offset + hub75_data_rgb_offset_out_green0] = instr | side_0;
    pio->instr_mem[offset + hub75_data_rgb_offset_out_red1] = instr | side_1;
    pio->instr_mem[offset + hub75_data_rgb_offset_out_green1] = instr | side_1;

    pio_sm_exec(pio, sm, offset + hub75_data_rgb_offset_entry_point);
    pio_sm_set_enabled(pio, sm, true);
}

// Patch a data program at `offset` to preshift pixels by `shamt`
static inline void hub75_data_rgb_set_shift(PIO pio, uint sm, uint offset, uint shamt) {
    uint16_t instr;
    if (shamt == 0)
        instr = pio_encode_pull(false, true); // blocking PULL
    else
        instr = pio_encode_out(pio_null, shamt);
    pio->instr_mem[offset + hub75_data_rgb_offset_shift0] = instr;
    pio->instr_mem[offset + hub75_data_rgb_offset_shift1] = instr;
}
%}